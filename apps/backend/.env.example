APP_ENV=development
APP_NAME=EvolvAI
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=evolvai
POSTGRES_PASSWORD=evolvai
POSTGRES_DB=evolvai_db
DATABASE_URL=postgresql+psycopg2://evolvai:evolvai@postgres:5432/evolvai_db

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REASONING_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_OUTPUT_TOKENS=1500
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2
OPENAI_TEMPERATURE=0.2

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_DEFAULT=llama-3.1-8b-instant
GROQ_MODEL_WATCHER=llama-3.1-8b-instant
GROQ_MODEL_RESEARCH=llama-3.1-8b-instant
GROQ_MODEL_STRATEGY=llama-3.1-8b-instant
GROQ_MODEL_PLANNER=llama-3.1-8b-instant
GROQ_MODEL_EXECUTION=llama-3.1-8b-instant
GROQ_MODEL_VERIFICATION=llama-3.1-8b-instant
GROQ_MODEL_PR=llama-3.1-8b-instant
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_MAX_OUTPUT_TOKENS=500
GROQ_TIMEOUT_SECONDS=30
GROQ_MAX_RETRIES=1
GROQ_TEMPERATURE=0.2

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_OUTPUT_TOKENS=1500
GEMINI_TEMPERATURE=0.2
XAI_API_KEY=
XAI_API_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-3-mini-latest
XAI_TIMEOUT_SECONDS=30
XAI_MAX_OUTPUT_TOKENS=1500
XAI_TEMPERATURE=0.2

GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_TARGET_OWNER=
GITHUB_TARGET_REPO=
GITHUB_BASE_BRANCH=main
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_INGESTION_ENABLED=true
GITHUB_SEARCH_QUERY=AI SaaS automation language:TypeScript stars:>500
GITHUB_SEARCH_MAX_RESULTS=10
GITHUB_RATE_LIMIT_SAFETY_ENABLED=true
GITHUB_REQUEST_TIMEOUT_SECONDS=20
GITHUB_MAX_RETRIES=2
GITHUB_PR_DRAFT=true
GITHUB_PR_BRANCH_PREFIX=evolvai/
GITHUB_PR_COMMIT_AUTHOR_NAME=EvolvAI Bot
GITHUB_PR_COMMIT_AUTHOR_EMAIL=evolvai-bot@example.com
GITHUB_PR_MAX_FILES=10
GITHUB_PR_REQUIRE_VERIFICATION_PASS=true
GITHUB_PR_ALLOWED_ARTIFACT_TYPES=documentation,component,schema,config,plan,report

HN_INGESTION_ENABLED=true
HN_API_BASE_URL=https://hacker-news.firebaseio.com/v0
HN_DEFAULT_FEED=top
HN_MAX_STORIES=20
HN_FETCH_DETAIL_CONCURRENCY=5
HN_REQUEST_TIMEOUT_SECONDS=15
HN_MAX_RETRIES=2
HN_MIN_SCORE=20
HN_MIN_IMPORTANCE_SCORE=0.45
HN_KEYWORDS=ai,artificial intelligence,llm,agent,saas,startup,workflow,automation,productivity,developer tools,compliance,security,rag,copilot

REPO_ANALYSIS_ENABLED=true
REPO_ANALYSIS_MAX_FILES=80
REPO_ANALYSIS_MAX_FILE_SIZE_BYTES=120000
REPO_ANALYSIS_ALLOWED_EXTENSIONS=.ts,.tsx,.js,.jsx,.py,.md,.json,.yml,.yaml,.toml,.env.example
REPO_ANALYSIS_EXCLUDED_DIRS=node_modules,.next,dist,build,.git,__pycache__,.venv,venv,coverage
REPO_ANALYSIS_INCLUDE_CONTENT=false
REPO_ANALYSIS_SUMMARIZE_WITH_LLM=true

CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=evolvai_memory

NEWS_API_KEY=
SERP_API_KEY=
GITHUB_TRENDS_ENABLED=true

TRACING_ENABLED=true
TRACING_PROVIDER=omium
OMIUM_API_KEY=
OMIUM_PROJECT_NAME=evolvai
OPENAI_TRACING_ENABLED=false

LOG_LEVEL=INFO
LOG_FORMAT=json

ALLOW_REAL_GITHUB_PR=false
ALLOW_CODE_EXECUTION=false
ALLOW_EXTERNAL_WRITE_ACTIONS=false
USE_LIVE_AI_OUTPUTS=true
USE_LIVE_EXTERNAL_EVENTS=true
USE_OPENAI_STRUCTURED_OUTPUTS=true
LLM_PROVIDER=groq
LLM_FALLBACK_TO_DEMO=true
LLM_LOG_PROMPTS=false
LLM_LOG_RESPONSES=false
LLM_CACHE_ENABLED=true
LLM_COMPACT_PROMPTS=true
LLM_MAX_PROMPT_CHARS=5000
LLM_MAX_EVIDENCE_ITEMS=3
LLM_MAX_CODEBASE_FILES=5
LLM_MAX_ARTIFACT_PREVIEW_CHARS=1500
LLM_AGENT_DELAY_MS=1500
LLM_RATE_LIMIT_COOLDOWN_SECONDS=8
MAX_LLM_AGENTS_PER_WORKFLOW=7
LLM_AGENT_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
LLM_SEQUENTIAL_AGENT_CALLS=true
ALLOW_LLM_ARTIFACT_CONTENT=true
ALLOW_LLM_FILE_PATHS=false
ALLOW_LLM_VERIFICATION_OVERRIDE=false
LIVE_EVENT_AUTO_TRIGGER=false
LIVE_EVENT_MIN_IMPORTANCE_SCORE=0.65
CHROMA_MEMORY_ENABLED=false
MEMORY_WRITE_ENABLED=false
DEMO_AGENT_DELAY_MS=700
DEMO_SPEED=normal
ALLOW_GENERATED_FILES=true
GENERATED_RUNS_DIR=generated_runs
MAX_ARTIFACT_SIZE_BYTES=100000
IMPACT_ACTION_THRESHOLD=0.5
CONFIDENCE_ACTION_THRESHOLD=0.5
